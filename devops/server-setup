run_setup() {
  step "4" "Installing & configuring"
  divider

  [[ "$DO_SYSTEM" == "y" ]]    && setup_system
  [[ "$DO_SECURITY" == "y" ]]  && setup_security
  [[ "$DO_SWAP" == "y" ]]      && setup_swap
  [[ "$DO_NODE" == "y" ]]      && setup_node
  [[ "$DO_PYTHON" == "y" ]]    && setup_python
  [[ "$DO_POSTGRES" == "y" ]]  && setup_postgres
  [[ "$DO_NGINX" == "y" ]]     && setup_nginx
  [[ "$DO_CERTBOT" == "y" ]]   && setup_certbot
  [[ "$DO_REDIS" == "y" ]]     && setup_redis
  [[ "$DO_DOCKER" == "y" ]]    && setup_docker
  [[ "$DO_LOGROTATE" == "y" ]] && setup_logrotate
}

