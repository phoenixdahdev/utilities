# ---------------------------
# Execution steps
# ---------------------------
create_database_if_needed() {
  if [[ "$USE_DB" != "y" ]]; then return; fi

  step "▸" "Database"

  local cpg_script
  cpg_script="$(dirname "$(readlink -f "$0")")/create-pg-database"
  if [[ ! -x "$cpg_script" ]]; then
    # Try same directory as deploy-app
    cpg_script="$(pwd)/create-pg-database"
  fi

  if [[ -x "$cpg_script" ]]; then
    "$cpg_script" --non-interactive \
      --db-name "$DB_NAME_VAL" \
      --user "$DB_USER_VAL" \
      --password "$DB_PASS_VAL" \
      --orm "$DB_ORM" || warn "Database setup returned non-zero; check output above."
  else
    warn "create-pg-database not found alongside this script. Creating DB inline ..."
    sudo -u postgres psql -q <<EOF
DO \$\$ BEGIN
  IF NOT EXISTS (SELECT FROM pg_roles WHERE rolname = '${DB_USER_VAL}') THEN
    CREATE ROLE "${DB_USER_VAL}" LOGIN PASSWORD '${DB_PASS_VAL}';
  END IF;
END \$\$;
EOF
    sudo -u postgres psql -tAc "SELECT 1 FROM pg_database WHERE datname='${DB_NAME_VAL}'" | grep -q 1 || \
      sudo -u postgres psql -q -c "CREATE DATABASE \"${DB_NAME_VAL}\" OWNER \"${DB_USER_VAL}\";"
    success "Database '${DB_NAME_VAL}' created"
  fi
}

write_env_file() {
  step "▸" "Writing .env"

  local env_path="$APP_DIR/.env"
  local tmp_env
  tmp_env=$(mktemp)

  # Start with user-provided content
  echo "$ENV_FILE_CONTENT" > "$tmp_env"

  # Append DATABASE_URL if we created a DB and user didn't already include one
  if [[ "$USE_DB" == "y" ]] && ! grep -q '^DATABASE_URL=' "$tmp_env" 2>/dev/null; then
    local pg_port
    pg_port=$(sudo -u postgres psql -tAc "SHOW port;" 2>/dev/null | xargs || echo "5432")
    echo "DATABASE_URL=postgresql://${DB_USER_VAL}:${DB_PASS_VAL}@localhost:${pg_port}/${DB_NAME_VAL}" \
      >> "$tmp_env"
  fi

  # Append PORT if not already set and we're non-static
  if [[ "$IS_STATIC" != "y" ]] && ! grep -q '^PORT=' "$tmp_env" 2>/dev/null; then
    echo "PORT=${APP_PORT}" >> "$tmp_env"
  fi

  # Move into place
  sudo mv "$tmp_env" "$env_path"
  sudo chown "$APP_USER:$APP_USER" "$env_path"
  sudo chmod 600 "$env_path"
  success ".env written to ${env_path}"
}

run_install_build() {
  if [[ -n "$INSTALL_CMD" ]]; then
    step "▸" "Install"
    info "Running: ${INSTALL_CMD}"
    as_app_user "cd '$APP_DIR' && $INSTALL_CMD"
    success "Install complete"
  fi

  if [[ -n "$BUILD_CMD" ]]; then
    step "▸" "Build"
    info "Running: ${BUILD_CMD}"
    as_app_user "cd '$APP_DIR' && $BUILD_CMD"
    success "Build complete"
  fi
}

write_nginx_config() {
  step "▸" "nginx site"

  local conf_path="$NGINX_AVAILABLE/$APP_NAME"

  if [[ "$IS_STATIC" == "y" ]]; then
    local root_path="$APP_DIR"
    [[ "$STATIC_DIR" != "." && "$STATIC_DIR" != "./" ]] && root_path="$APP_DIR/$STATIC_DIR"

    sudo tee "$conf_path" >/dev/null <<NGINX
server {
    listen 80;
    listen [::]:80;
    server_name ${APP_DOMAIN};

    root ${root_path};
    index index.html;

    access_log /var/log/nginx/${APP_NAME}.access.log;
    error_log  /var/log/nginx/${APP_NAME}.error.log;

    include /etc/nginx/snippets/security-headers.conf;

    location / {
        try_files \$uri \$uri/ /index.html;
    }

    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)\$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }
}
NGINX
  else
    sudo tee "$conf_path" >/dev/null <<NGINX
server {
    listen 80;
    listen [::]:80;
    server_name ${APP_DOMAIN};

    access_log /var/log/nginx/${APP_NAME}.access.log;
    error_log  /var/log/nginx/${APP_NAME}.error.log;

    include /etc/nginx/snippets/security-headers.conf;

    client_max_body_size 50M;

    location / {
        proxy_pass http://127.0.0.1:${APP_PORT};
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_cache_bypass \$http_upgrade;
        proxy_read_timeout 60s;
    }
}
NGINX
  fi

  # Enable
  sudo ln -sf "$conf_path" "$NGINX_ENABLED/$APP_NAME"

  # Test + reload
  if sudo nginx -t >/dev/null 2>&1; then
    sudo systemctl reload nginx
    success "nginx configured and reloaded"
  else
    error "nginx config test failed. Config at ${conf_path}"
    sudo nginx -t
    exit 1
  fi
}

get_ssl_certificate() {
  if [[ "$USE_SSL" != "y" ]]; then return; fi

  step "▸" "SSL certificate"

  if ! has_cmd certbot; then
    warn "certbot not installed — skipping SSL. Run ./server-setup to add it."
    return
  fi

  info "Requesting Let's Encrypt cert for ${APP_DOMAIN} ..."
  if sudo certbot --nginx \
    --non-interactive --agree-tos \
    --email "$SSL_EMAIL" \
    --domain "$APP_DOMAIN" \
    --redirect; then
    success "SSL certificate installed"
  else
    warn "certbot failed — your app is still running on HTTP. Re-run after fixing DNS."
  fi
}

start_pm2_process() {
  if [[ "$IS_STATIC" == "y" ]]; then
    info "Static site — nginx serves files directly, no pm2 process needed."
    return
  fi

  if [[ "$APP_TYPE" == "docker" ]]; then
    step "▸" "Docker"
    info "Starting docker compose ..."
    as_app_user "cd '$APP_DIR' && docker compose up -d"
    success "Docker containers started"
    return
  fi

  step "▸" "PM2 process"

  # Stop existing if present
  if as_app_user "pm2 list 2>/dev/null | grep -q \" $APP_NAME \""; then
    info "Reloading existing pm2 process ..."
    as_app_user "pm2 reload $APP_NAME --update-env"
  else
    info "Starting pm2 process: ${APP_NAME}"
    # Use --cwd + raw command for maximum compatibility
    as_app_user "cd '$APP_DIR' && pm2 start '$START_CMD' --name '$APP_NAME' --cwd '$APP_DIR'"
  fi

  # Save process list for boot persistence
  as_app_user "pm2 save" >/dev/null 2>&1
  success "pm2 process '${APP_NAME}' running"
}

save_deploy_state() {
  local state_file="$APP_DIR/.deploy-state"
  sudo -u "$APP_USER" tee "$state_file" >/dev/null <<EOF
# Auto-generated by deploy-app. Do not edit.
APP_NAME="${APP_NAME}"
APP_TYPE="${APP_TYPE}"
APP_SUBFRAMEWORK="${APP_SUBFRAMEWORK}"
APP_PM="${APP_PM}"
APP_PORT="${APP_PORT}"
APP_DOMAIN="${APP_DOMAIN}"
INSTALL_CMD="${INSTALL_CMD}"
BUILD_CMD="${BUILD_CMD}"
START_CMD="${START_CMD}"
IS_STATIC="${IS_STATIC}"
STATIC_DIR="${STATIC_DIR}"
DEPLOYED_AT="$(date -Iseconds)"
EOF
}

