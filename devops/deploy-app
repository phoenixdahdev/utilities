# ---------------------------
# Parse flags
# ---------------------------
CMD=""
CMD_ARG=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --redeploy)     CMD="redeploy"; CMD_ARG="$2"; shift 2 ;;
    --list)         CMD="list"; shift ;;
    --logs)         CMD="logs"; CMD_ARG="$2"; shift 2 ;;
    --remove)       CMD="remove"; CMD_ARG="$2"; shift 2 ;;
    --restart)      CMD="restart"; CMD_ARG="$2"; shift 2 ;;
    --name)         APP_NAME="$2"; shift 2 ;;
    --repo)         APP_REPO="$2"; shift 2 ;;
    --path)         APP_PATH="$2"; shift 2 ;;
    --branch)       APP_BRANCH="$2"; shift 2 ;;
    --domain)       APP_DOMAIN="$2"; shift 2 ;;
    --port)         APP_PORT="$2"; shift 2 ;;
    --type)         APP_TYPE="$2"; shift 2 ;;
    --no-ssl)       USE_SSL="n"; shift ;;
    --no-db)        USE_DB="skip"; shift ;;
    --help|-h)      show_help ;;
    *)              error "Unknown option: $1"; echo; show_help ;;
  esac
done

# ---------------------------
# Dispatch
# ---------------------------
case "$CMD" in
  list)      cmd_list ;;
  logs)      cmd_logs "$CMD_ARG" ;;
  restart)   cmd_restart "$CMD_ARG" ;;
  remove)    cmd_remove "$CMD_ARG" ;;
  redeploy)
    check_server_readiness
    cmd_redeploy "$CMD_ARG"
    ;;
esac

# ---------------------------
# Main wizard
# ---------------------------
echo
echo -e "${BOLD}${CYAN}╔══════════════════════════════════════════════╗${RESET}"
echo -e "${BOLD}${CYAN}║${RESET}   ${BOLD}App Deployment Wizard${RESET}                       ${BOLD}${CYAN}║${RESET}"
