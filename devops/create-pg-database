    echo -e "    username: '${DB_USER}', password: '<password>', database: '${DB_NAME}' }${RESET}"
  fi
  echo
}

# ---------------------------
# Defaults
# ---------------------------
DB_NAME=""
DB_USER=""
DB_PASS=""
ORM=""
MAKE_OWNER="n"
USE_EXISTING_USER="n"
NON_INTERACTIVE="n"
DB_ALREADY_EXISTS="n"
ROLE_ALREADY_EXISTS="n"
CMD_LIST_USERS="n"
CMD_CHANGE_PASS="n"
CMD_GRANT_CREATEDB="n"
CMD_LIST_DBS="n"
CMD_DROP_DB="n"
CMD_DROP_USER="n"
CMD_BACKUP="n"
CMD_RESTORE="n"
CMD_CONN_TEST="n"
CMD_DB_INFO="n"
BACKUP_FILE=""
BACKUP_FORMAT=""

# ---------------------------
# Parse flags
# ---------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
    --list-users)
      CMD_LIST_USERS="y"; shift ;;
    --list-databases)
      CMD_LIST_DBS="y"; shift ;;
    --change-password)
      CMD_CHANGE_PASS="y"; shift ;;
    --grant-createdb)
      CMD_GRANT_CREATEDB="y"; shift ;;
    --drop-database)
      CMD_DROP_DB="y"; shift ;;
    --drop-user)
      CMD_DROP_USER="y"; shift ;;
    --backup)
      CMD_BACKUP="y"; shift ;;
    --restore)
      CMD_RESTORE="y"; shift ;;
    --connection-test)
      CMD_CONN_TEST="y"; shift ;;
    --db-info)
      CMD_DB_INFO="y"; shift ;;
    --db-name)
      DB_NAME="$2"; shift 2 ;;
    --user)
      DB_USER="$2"; shift 2 ;;
    --password)
      DB_PASS="$2"; shift 2 ;;
    --orm)
      ORM="$2"; shift 2 ;;
    --file)
      BACKUP_FILE="$2"; shift 2 ;;
    --format)
      BACKUP_FORMAT="$2"; shift 2 ;;
    --owner)
      MAKE_OWNER="y"; shift ;;
    --existing-user)
      USE_EXISTING_USER="y"; shift ;;
    --non-interactive)
      NON_INTERACTIVE="y"; shift ;;
    --help|-h)
      show_help ;;
    *)
      error "Unknown option: $1"
      echo
      show_help ;;
  esac
done

# ---------------------------
# Dispatch commands
# ---------------------------
[[ "$CMD_LIST_USERS" == "y" ]]     && cmd_list_users
[[ "$CMD_LIST_DBS" == "y" ]]       && cmd_list_databases
[[ "$CMD_CHANGE_PASS" == "y" ]]    && cmd_change_password
[[ "$CMD_GRANT_CREATEDB" == "y" ]] && cmd_grant_createdb
[[ "$CMD_DROP_DB" == "y" ]]        && cmd_drop_database
[[ "$CMD_DROP_USER" == "y" ]]   && cmd_drop_user
[[ "$CMD_BACKUP" == "y" ]]      && cmd_backup
[[ "$CMD_RESTORE" == "y" ]]     && cmd_restore
[[ "$CMD_CONN_TEST" == "y" ]]   && cmd_connection_test
[[ "$CMD_DB_INFO" == "y" ]]     && cmd_db_info

# ---------------------------
# Non-interactive validation
# ---------------------------
if [[ "$NON_INTERACTIVE" == "y" ]]; then
  [[ -z "$DB_NAME" ]] && { error "--db-name is required in non-interactive mode."; exit 1; }
  [[ -z "$DB_USER" ]] && { error "--user is required in non-interactive mode."; exit 1; }
  [[ "$USE_EXISTING_USER" != "y" && -z "$DB_PASS" ]] && {
    error "--password is required in non-interactive mode (unless --existing-user)."; exit 1;
  }
  [[ "$MAKE_OWNER" != "y" && -z "$ORM" ]] && {
    error "--orm is required in non-interactive mode (unless --owner)."; exit 1;
  }
fi

# ---------------------------
# Banner
# ---------------------------
echo
echo -e "${BOLD}${CYAN}╔══════════════════════════════════════════════╗${RESET}"
echo -e "${BOLD}${CYAN}║${RESET}   ${BOLD}PostgreSQL Database Provisioner${RESET}             ${BOLD}${CYAN}║${RESET}"
echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════════╝${RESET}"

# ---------------------------
# Main flow
# ---------------------------
show_pg_environment
collect_input
show_plan
execute
show_summary
