# ---------------------------
# Installers
# ---------------------------
install_essentials() {
  info "Installing system essentials ..."
  sudo apt update -qq
  sudo apt install -y -qq git curl wget build-essential software-properties-common \
    ca-certificates gnupg lsb-release unzip >/dev/null
  success "Essentials installed"
}

install_zsh() {
  if has_cmd zsh; then
    success "Zsh already installed"
  else
    info "Installing zsh ..."
    sudo apt install -y -qq zsh >/dev/null
    success "Zsh installed"
  fi

  # Set as default shell if not already
  local current_shell
  current_shell=$(getent passwd "$USER" | cut -d: -f7)
  if [[ "$current_shell" != *"zsh"* ]]; then
    info "Setting zsh as default shell ..."
    sudo chsh -s "$(which zsh)" "$USER"
    success "Default shell set to zsh"
  else
    success "Zsh is already default shell"
  fi
}

install_ohmyzsh() {
  if [[ -d "$HOME/.oh-my-zsh" ]]; then
    success "Oh My Zsh already installed"
  else
    info "Installing Oh My Zsh ..."
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
    success "Oh My Zsh installed"
  fi

  # zsh-syntax-highlighting
  local plugin_dir="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins"
  if [[ -d "$plugin_dir/zsh-syntax-highlighting" ]]; then
    success "zsh-syntax-highlighting already installed"
  else
    info "Installing zsh-syntax-highlighting ..."
    git clone --quiet https://github.com/zsh-users/zsh-syntax-highlighting.git \
      "$plugin_dir/zsh-syntax-highlighting"
    success "zsh-syntax-highlighting installed"
  fi

  # zsh-autosuggestions
  if [[ -d "$plugin_dir/zsh-autosuggestions" ]]; then
    success "zsh-autosuggestions already installed"
  else
    info "Installing zsh-autosuggestions ..."
    git clone --quiet https://github.com/zsh-users/zsh-autosuggestions.git \
      "$plugin_dir/zsh-autosuggestions"
    success "zsh-autosuggestions installed"
  fi
}

install_zshrc() {
  if [[ -f "$HOME/.zshrc" ]]; then
    local backup="$HOME/.zshrc.backup.$(date +%Y%m%d%H%M%S)"
    warn "Existing .zshrc backed up to ${backup}"
    cp "$HOME/.zshrc" "$backup"
  fi
  echo "$ZSHRC_CONTENT" > "$HOME/.zshrc"
  success ".zshrc written"
}

install_ghostty() {
  if has_cmd ghostty; then
    success "Ghostty already installed ($(ghostty --version 2>/dev/null | head -1))"
  else
    info "Installing Ghostty via snap ..."
    sudo snap install ghostty --classic
    success "Ghostty installed"
  fi

  # Ensure config directory exists
  mkdir -p "$HOME/.config/ghostty"
  success "Ghostty config dir ready at ~/.config/ghostty/"
}

install_nvm() {
  local nvm_dir="${NVM_DIR:-$HOME/.config/nvm}"

  if [[ -s "$nvm_dir/nvm.sh" ]]; then
    success "NVM already installed"
  else
    info "Installing NVM ..."
    export NVM_DIR="$nvm_dir"
    mkdir -p "$NVM_DIR"
    curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash
    success "NVM installed at $nvm_dir"
  fi

  # Load nvm for this session
  export NVM_DIR="$nvm_dir"
  # shellcheck disable=SC1091
  [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

  if has_cmd node; then
    success "Node.js already installed ($(node --version))"
  else
    info "Installing Node.js LTS ..."
    nvm install --lts
    nvm use --lts
    nvm alias default lts/*
    success "Node.js LTS installed ($(node --version))"
  fi
}

install_pnpm() {
  if has_cmd pnpm; then
    success "pnpm already installed ($(pnpm --version))"
  else
    info "Installing pnpm ..."
    curl -fsSL https://get.pnpm.io/install.sh | sh -
    success "pnpm installed"
  fi
}

install_bun() {
  if has_cmd bun; then
    success "Bun already installed ($(bun --version))"
  else
    info "Installing Bun ..."
    curl -fsSL https://bun.sh/install | bash
    success "Bun installed"
  fi
}

install_python() {
  if has_cmd python3; then
    success "Python3 already installed ($(python3 --version))"
  else
    info "Installing Python3 ..."
    sudo apt install -y -qq python3 >/dev/null
    success "Python3 installed"
  fi

  if has_cmd pip3; then
    success "pip3 already installed"
  else
    info "Installing pip3 ..."
    sudo apt install -y -qq python3-pip >/dev/null
    success "pip3 installed"
  fi

  if python3 -c "import venv" 2>/dev/null; then
    success "python3-venv already available"
  else
    info "Installing python3-venv ..."
    sudo apt install -y -qq python3-venv >/dev/null
    success "python3-venv installed"
  fi
}

install_postgres() {
  if has_cmd psql; then
    success "PostgreSQL already installed (psql $(psql --version | awk '{print $3}'))"
  else
    info "Installing PostgreSQL from PGDG ..."
    sudo apt install -y -qq curl ca-certificates >/dev/null
    sudo install -d /usr/share/postgresql-common/pgdg
    sudo curl -fsSL -o /usr/share/postgresql-common/pgdg/apt.postgresql.org.asc \
      https://www.postgresql.org/media/keys/ACCC4CF8.asc
    echo "deb [signed-by=/usr/share/postgresql-common/pgdg/apt.postgresql.org.asc] \
https://apt.postgresql.org/pub/repos/apt $(lsb_release -cs)-pgdg main" | \
      sudo tee /etc/apt/sources.list.d/pgdg.list >/dev/null
    sudo apt update -qq
    sudo apt install -y -qq postgresql >/dev/null
    success "PostgreSQL installed"
  fi

  # Ensure service is running
  if sudo systemctl is-active postgresql &>/dev/null; then
    success "PostgreSQL service is running"
  else
    info "Starting PostgreSQL service ..."
    sudo systemctl start postgresql
    sudo systemctl enable postgresql
    success "PostgreSQL started and enabled"
  fi
}

install_nginx() {
  if has_cmd nginx; then
    success "nginx already installed"
  else
    info "Installing nginx ..."
    sudo apt install -y -qq nginx >/dev/null
    success "nginx installed"
  fi
  sudo systemctl start nginx 2>/dev/null || true
  sudo systemctl enable nginx 2>/dev/null || true
  success "nginx is running"
}

install_certbot() {
  if has_cmd certbot; then
    success "certbot already installed"
  else
    info "Installing certbot ..."
    sudo apt install -y -qq certbot python3-certbot-nginx >/dev/null
    success "certbot installed"
  fi
}

install_docker() {
  if has_cmd docker; then
    success "Docker already installed ($(docker --version))"
  else
    info "Installing Docker Engine ..."
    # Add Docker GPG key
    sudo install -m 0755 -d /etc/apt/keyrings
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg | \
      sudo gpg --dearmor -o /etc/apt/keyrings/docker.gpg 2>/dev/null
    sudo chmod a+r /etc/apt/keyrings/docker.gpg

    # Add Docker repo
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] \
https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" | \
      sudo tee /etc/apt/sources.list.d/docker.list >/dev/null

    sudo apt update -qq
    sudo apt install -y -qq docker-ce docker-ce-cli containerd.io \
      docker-buildx-plugin docker-compose-plugin >/dev/null
    success "Docker installed"
  fi

  # Add user to docker group
  if groups "$USER" | grep -q docker; then
    success "User already in docker group"
  else
    info "Adding $USER to docker group ..."
    sudo usermod -aG docker "$USER"
    success "Added to docker group (log out and back in to take effect)"
  fi

  sudo systemctl start docker 2>/dev/null || true
  sudo systemctl enable docker 2>/dev/null || true
  success "Docker is running"
}

install_redis() {
  if has_cmd redis-cli; then
    success "Redis already installed"
  else
    info "Installing Redis ..."
    sudo apt install -y -qq redis-server >/dev/null
    success "Redis installed"
  fi
  sudo systemctl start redis-server 2>/dev/null || true
  sudo systemctl enable redis-server 2>/dev/null || true
  success "Redis is running"
}

install_ufw() {
  if ! has_cmd ufw; then
    info "Installing UFW ..."
    sudo apt install -y -qq ufw >/dev/null
  fi
  info "Configuring UFW ..."
  sudo ufw default deny incoming >/dev/null
  sudo ufw default allow outgoing >/dev/null
  sudo ufw allow ssh >/dev/null
  sudo ufw allow http >/dev/null
  sudo ufw allow https >/dev/null
  sudo ufw --force enable >/dev/null
  success "UFW enabled (SSH + HTTP + HTTPS allowed)"
}

# ---------------------------
# Execute all
# ---------------------------
run_installs() {
  step "4" "Installing"
  divider

  [[ "$INSTALL_ESSENTIALS" == "y" ]] && install_essentials
  [[ "$INSTALL_ZSH" == "y" ]]        && install_zsh
  [[ "$INSTALL_OHMYZSH" == "y" ]]    && install_ohmyzsh
  [[ "$INSTALL_ZSHRC" == "y" ]]      && install_zshrc
  [[ "$INSTALL_GHOSTTY" == "y" ]]    && install_ghostty
  [[ "$INSTALL_NVM" == "y" ]]        && install_nvm
  [[ "$INSTALL_PNPM" == "y" ]]       && install_pnpm
  [[ "$INSTALL_BUN" == "y" ]]        && install_bun
  [[ "$INSTALL_PYTHON" == "y" ]]     && install_python
  [[ "$INSTALL_POSTGRES" == "y" ]]   && install_postgres
  [[ "$INSTALL_NGINX" == "y" ]]      && install_nginx
  [[ "$INSTALL_CERTBOT" == "y" ]]    && install_certbot
  [[ "$INSTALL_DOCKER" == "y" ]]     && install_docker
  [[ "$INSTALL_REDIS" == "y" ]]      && install_redis
  [[ "$INSTALL_UFW" == "y" ]]        && install_ufw
}

