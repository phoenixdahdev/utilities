# ---------------------------
# Parse flags
# ---------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
    --all)
      INSTALL_ALL="y"; shift ;;
    --skip-detect)
      SKIP_DETECT="y"; shift ;;
    --help|-h)
      show_help ;;
    *)
      error "Unknown option: $1"
      echo
      show_help ;;
  esac
done

