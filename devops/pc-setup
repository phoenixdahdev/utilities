# ---------------------------
# Detect current environment
# ---------------------------
show_environment() {
  step "1" "Current Environment"
  divider

  local os_name kernel arch mem disk cpus
  os_name=$(. /etc/os-release 2>/dev/null && echo "$PRETTY_NAME" || echo "Unknown")
  kernel=$(uname -r)
  arch=$(uname -m)
  mem=$(free -h | awk '/Mem:/{print $2}')
  disk=$(df -h / | awk 'NR==2{print $4 " free / " $2 " total"}')
  cpus=$(nproc)

  echo -e "  ${DIM}OS .............${RESET} ${WHITE}${os_name}${RESET}"
  echo -e "  ${DIM}Kernel .........${RESET} ${WHITE}${kernel} (${arch})${RESET}"
  echo -e "  ${DIM}CPU ............${RESET} ${WHITE}${cpus} cores${RESET}"
  echo -e "  ${DIM}Memory .........${RESET} ${WHITE}${mem}${RESET}"
  echo -e "  ${DIM}Disk ...........${RESET} ${WHITE}${disk}${RESET}"

  echo
  echo -e "  ${UNDERLINE}Core tools:${RESET}"
  detect_status "zsh $(zsh --version 2>/dev/null | awk '{print $2}' || true)" "has_cmd zsh" || true
  detect_status "Oh My Zsh" "[ -d \"\$HOME/.oh-my-zsh\" ]" || true
  detect_status "Ghostty $(ghostty --version 2>/dev/null | head -1 | awk '{print $2}' || true)" "has_cmd ghostty" || true
  detect_status "Git $(git --version 2>/dev/null | awk '{print $3}' || true)" "has_cmd git" || true
  detect_status "curl" "has_cmd curl" || true

  echo
  echo -e "  ${UNDERLINE}Languages & runtimes:${RESET}"
  detect_status "NVM" "[ -d \"\${NVM_DIR:-\$HOME/.config/nvm}\" ] && [ -s \"\${NVM_DIR:-\$HOME/.config/nvm}/nvm.sh\" ]" || true
  detect_status "Node.js $(node --version 2>/dev/null || true)" "has_cmd node" || true
  detect_status "npm $(npm --version 2>/dev/null || true)" "has_cmd npm" || true
  detect_status "pnpm $(pnpm --version 2>/dev/null || true)" "has_cmd pnpm" || true
  detect_status "Bun $(bun --version 2>/dev/null || true)" "has_cmd bun" || true
  detect_status "Python3 $(python3 --version 2>/dev/null | awk '{print $2}' || true)" "has_cmd python3" || true
  detect_status "pip3" "has_cmd pip3" || true

  echo
  echo -e "  ${UNDERLINE}Services:${RESET}"
  detect_status "PostgreSQL (psql $(psql --version 2>/dev/null | awk '{print $3}' || true))" "has_cmd psql" || true
  detect_status "nginx" "has_cmd nginx" || true
  detect_status "Docker" "has_cmd docker" || true
  detect_status "Redis" "has_cmd redis-cli" || true
}

